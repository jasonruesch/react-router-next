{
  "name": "react-router-next-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w react-router-next && npm run build -w demo",
    "dev": "npm run dev -w demo",
    "lint": "npm run lint --workspaces --if-present",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
