{
  "name": "@evolonix/react-router-next",
  "version": "0.3.0",
  "description": "Next.js-style filesystem routing for React Router 7, with a Vite plugin that generates per-route typed params.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "react-router-next": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evolonix/react-router-next.git",
    "directory": "packages/react-router-next"
  },
  "bugs": {
    "url": "https://github.com/evolonix/react-router-next/issues"
  },
  "homepage": "https://github.com/evolonix/react-router-next#readme",
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "react-router": ">=7",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "tsup": "^8.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "react",
    "react-router",
    "router",
    "filesystem-routing",
    "app-router",
    "nextjs",
    "vite",
    "vite-plugin",
    "typegen"
  ]
}
